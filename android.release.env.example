# Copy this file to .env.android.release.local and fill in your real values.

# Required for signing the release bundle.
ANDROID_KEYSTORE_PATH=relative/or/absolute/path/to/sofull-release.keystore
ANDROID_KEYSTORE_PASSWORD=change-me
ANDROID_KEY_ALIAS=sofull
ANDROID_KEY_PASSWORD=change-me

# Required for publishing to Google Play.
# Option A: point to the service-account JSON file.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=relative/or/absolute/path/to/google-play-service-account.json

# Option B: paste the entire JSON into GOOGLE_PLAY_SERVICE_ACCOUNT_JSON instead.
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional overrides.
GOOGLE_PLAY_TRACK=internal
# GOOGLE_PLAY_PACKAGE_NAME=com.sofull.site
# ANDROID_VERSION_CODE=123
# ANDROID_VERSION_NAME=1.0.6
